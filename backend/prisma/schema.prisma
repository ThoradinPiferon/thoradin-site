// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User Management
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  username  String   @unique
  password  String
  role      UserRole @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  gridInteractions GridInteraction[]
  configurations   Configuration[]
  themes          Theme[]
  contents        Content[]
  aiResponses     AIResponse[]
  gridSessions    GridSession[]

  @@map("users")
}

enum UserRole {
  ADMIN
  MODERATOR
  USER
}

// Grid Interactions
model GridInteraction {
  id              String   @id @default(cuid())
  userId          String?
  gridRow         Int
  gridCol         Int
  interactionType String   // click, hover, longPress
  emotionalState  String?
  symbolicContext String?
  aiResponse      String?
  responseTime    Int?
  tokensUsed      Int?
  model           String?
  createdAt       DateTime @default(now())

  // Relations
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  aiResponses     AIResponse[]

  @@map("grid_interactions")
}

// AI Responses
model AIResponse {
  id                String   @id @default(cuid())
  gridInteractionId String
  userId            String?
  prompt            String
  response          String
  model             String
  tokensUsed        Int?
  responseTime      Int?
  createdAt         DateTime @default(now())

  // Relations
  gridInteraction GridInteraction @relation(fields: [gridInteractionId], references: [id], onDelete: Cascade)
  user            User?           @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("ai_responses")
}

// Grid Sessions
model GridSession {
  id          String   @id @default(cuid())
  userId      String
  sessionName String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("grid_sessions")
}

// Configuration Management
model Configuration {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  type        ConfigType
  category    String   // animation, ui, content, theme
  isActive    Boolean  @default(true)
  version     Int      @default(1)
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  user User? @relation(fields: [createdBy], references: [id], onDelete: SetNull)

  @@map("configurations")
}

enum ConfigType {
  STRING
  JSON
  NUMBER
  BOOLEAN
  ARRAY
}

// Theme Management
model Theme {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  isDefault   Boolean  @default(false)
  config      Json     // Theme-specific configurations
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  user User? @relation(fields: [createdBy], references: [id], onDelete: SetNull)

  @@map("themes")
}

// Content Management
model Content {
  id          String   @id @default(cuid())
  key         String
  content     String
  type        ContentType
  language    String   @default("en")
  isProtected Boolean  @default(false)
  isActive    Boolean  @default(true)
  version     Int      @default(1)
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  user User? @relation(fields: [createdBy], references: [id], onDelete: SetNull)

  // Composite unique constraint for key + language
  @@unique([key, language])
  @@map("contents")
}

enum ContentType {
  ANIMATION_TEXT
  UI_TEXT
  STORY_CONTENT
  AI_PROMPT
  MOCK_RESPONSE
  METADATA
} 